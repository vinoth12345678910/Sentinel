{
  "name": "sentinel-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Sentinel deployment control plane",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "prod": "pm2 start ecosystem.config.js",
    "prod:stop": "pm2 stop sentinel",
    "prod:restart": "pm2 restart sentinel",
    "prod:logs": "pm2 logs sentinel",
    "prod:status": "pm2 status"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "better-sqlite3@12.10.0": true
  }
}
