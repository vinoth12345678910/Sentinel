# Production API URL — the backend server URL your deployment will call.
# For a local dev build served via Nginx that proxies /api to the backend,
# set this to the backend's externally reachable URL.
# Example: NEXT_PUBLIC_API_URL=https://api.example.com
#
# NOTE: Next.js inlines this at build time. It must be set before building
# the static export, and must be reachable from the browser at runtime.
NEXT_PUBLIC_API_URL=
