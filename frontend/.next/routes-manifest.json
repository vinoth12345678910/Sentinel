{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/dashboard/apps/[name]",
      "regex": "^/dashboard/apps/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname"
      },
      "namedRegex": "^/dashboard/apps/(?<nxtPname>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/apps/[name]/deployments/[id]",
      "regex": "^/dashboard/apps/([^/]+?)/deployments/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/apps/(?<nxtPname>[^/]+?)/deployments/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/projects/[id]",
      "regex": "^/dashboard/projects/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/projects/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/audit",
      "regex": "^/admin/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/audit(?:/)?$"
    },
    {
      "page": "/admin/security",
      "regex": "^/admin/security(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/security(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/activity",
      "regex": "^/dashboard/activity(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/activity(?:/)?$"
    },
    {
      "page": "/dashboard/apps",
      "regex": "^/dashboard/apps(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/apps(?:/)?$"
    },
    {
      "page": "/dashboard/create",
      "regex": "^/dashboard/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/create(?:/)?$"
    },
    {
      "page": "/dashboard/monitoring",
      "regex": "^/dashboard/monitoring(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/monitoring(?:/)?$"
    },
    {
      "page": "/dashboard/projects",
      "regex": "^/dashboard/projects(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/projects(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/dashboard/teams",
      "regex": "^/dashboard/teams(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/teams(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}